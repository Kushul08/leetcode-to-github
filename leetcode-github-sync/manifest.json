{
  "manifest_version": 3,
  "name": "LeetCode → GitHub Sync",
  "version": "1.2.0",
  "description": "Automatically pushes accepted LeetCode solutions to your GitHub repository.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode GitHub Sync"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
